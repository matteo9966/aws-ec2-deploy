{
  "name": "aws-ec2-deploy",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript Express server bundled for EC2 deployment",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "bundle": "tsup --config tsup.config.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "multer": "2.1.1",
    "pg": "^8.20.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@aws-ec2-deploy/types": "*",
    "@eslint/js": "^9.37.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.6.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.37.0",
    "prisma": "^7.5.0",
    "supertest": "^7.1.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}
